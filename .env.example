# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Estabelecimento (Multi-tenant)
VITE_ESTABELECIMENTO_ID=539eef80-ec1a-4567-98a2-f5dd0ab1c8c4

# Impressora Térmica
PRINTER_INTERFACE=tcp://192.168.1.100:9100
# ou para USB: PRINTER_INTERFACE=printer:PrinterName

# Ambiente
NODE_ENV=development

# GitHub Token (necessário APENAS para publicar releases via electron-builder)
# Crie em: https://github.com/settings/tokens → permissão "repo"
# Não é necessário nos apps dos clientes — só na máquina que faz o build/CI
GH_TOKEN=
